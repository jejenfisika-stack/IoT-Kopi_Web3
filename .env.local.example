# ── Pinata (IPFS) ──────────────────────────────────────────
# Ambil di https://app.pinata.cloud → API Keys → New Key (centang pinJSONToIPFS).
# Salin file ini menjadi .env.local lalu isi nilainya. JANGAN commit .env.local.
PINATA_API_KEY=isi_api_key_anda
PINATA_API_SECRET=isi_api_secret_anda

# Opsional: gateway khusus Pinata Anda (default: gateway.pinata.cloud)
# Contoh: rose-casual-warbler-710.mypinata.cloud
PINATA_GATEWAY=gateway.pinata.cloud
